# ---------------------------------------------------------------------------
# Auto-heal the local terminal after an ssh session ends.
#
# When the remote (tmux/vim/etc.) puts kitty into alt-screen, mouse-tracking
# and the kitty keyboard protocol, an abrupt disconnect (wifi drop / laptop
# sleep) kills ssh before the remote can undo those modes. ssh restores the
# local tty line discipline on exit but cannot undo emulator state, so the
# terminal is left unable to scroll with broken keys. This sends the specific
# "undo" sequences after ssh returns (any exit reason). Instant, and a no-op
# when nothing was broken -- unlike `reset`, which also wipes scrollback.
_reset_term_modes() {
  [[ -t 1 ]] || return 0   # only for an interactive terminal (skip -Nf tunnels)
  printf '\033[<u\033[<u\033[<u'                       # pop kitty keyboard protocol stack
  printf '\033[?1049l'                                 # leave alternate screen -> restores scrolling
  printf '\033[?1l\033>'                               # normal cursor keys + keypad
  printf '\033[?2004l'                                 # disable bracketed paste
  printf '\033[?1000l\033[?1002l\033[?1003l\033[?1006l\033[?1015l' # disable mouse tracking
  printf '\033[?1004l'                                 # disable focus reporting
  printf '\033[?7h\033[?25h\033[0m'                    # autowrap on, cursor visible, reset attrs
  stty sane 2>/dev/null                                # restore line discipline
}
ssh() {
  command ssh "$@"
  local ret=$?
  _reset_term_modes
  return $ret
}
