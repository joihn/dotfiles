abspath() {
    if [ -z "$1" ]; then
        echo "Usage: abspath <relative-path>"
        return 1
    fi

    local rel_path="$1"
    local abs_path

    if [ "$rel_path" = "." ]; then
        abs_path=$(cd "$(dirname "$rel_path")" && pwd)
    else
        abs_path=$(cd "$(dirname "$rel_path")" && pwd)/$(basename "$rel_path")
    fi

    echo -n "$abs_path"
}
fpc(){
     #readlink -f $1 | xclip -sel clip # will resolve symlink, undesired
     abspath $1 | kitten clipboard
    
}

fpcc() {
  if [[ $# -ne 1 ]]; then
    echo "Usage: fpcc <file>"
    return 1
  fi

  if [[ ! -f $1 ]]; then
    echo "Error: '$1' is not a valid file."
    return 1
  fi

  # Resolve absolute file path and create a valid file URI
  local filepath=$(readlink -f "$1")
  local uri="file://$filepath"

  # Create a temporary file for the URI and ensure cleanup after use
  local tmpfile=$(mktemp /tmp/fileuri.XXXXXX)
  echo -n "$uri" > "$tmpfile"

  # Copy the file URI with the correct MIME type to the clipboard
  kitten clipboard --mime text/uri-list "$tmpfile"

  # Remove the temporary file
  rm "$tmpfile"
}


