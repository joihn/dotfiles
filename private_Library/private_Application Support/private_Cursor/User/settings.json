"editor.tokenColorCustomizations": {
  "textMateRules": [
    {
      // VSCode's built-in TextMate grammar for Markdown does not provide a scope for the entire heading line.
      // As a workaround, we color both the '#' and the heading text, as well as fallback to string.markdown.
      // This still may not fully color the line due to TextMate grammar limitations.
      "scope": [
        "markup.heading",
        "markup.heading.markdown",
        "markup.heading.markdown punctuation.definition.heading.markdown",
        "markup.heading.markdown string",
        "entity.name.section.markdown",
        "string.markdown"
      ],
      "settings": {
        "foreground": "#75ac83",
        
      }
    }
  ]
},
